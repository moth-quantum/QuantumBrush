{
  "name": "Quantum Walk",
  "id": "qwalk",
  "author": "zkasuran",
  "version": "0.1.0",
  "description": "Spreads paint along the stroke as a continuous-time quantum walk. A coherence dial morphs between the quantum walk (ballistic spread with interference fringes) and the classical heat kernel (smooth diffusion) on the same graph.",
  "dependencies": {
    "numpy": ">=2.1.0",
    "qiskit": ">=1.0.0",
    "scipy": ">=1.10.0"
  },
  "user_input": {
    "Radius": {
      "type": "int",
      "min": 2,
      "max": 60,
      "default": 18
    },
    "Time": {
      "type": "float",
      "min": 0.5,
      "max": 20.0,
      "default": 6.0
    },
    "Coherence": {
      "type": "float",
      "min": 0.0,
      "max": 1.0,
      "default": 1.0
    },
    "Steps": {
      "type": "int",
      "min": 1,
      "max": 80,
      "default": 24
    },
    "Target Color": {
      "type": "color",
      "default": "#FF5733"
    }
  },
  "stroke_input": {
    "image_rgba": "array",
    "path": "array"
  },
  "flags": {
    "smooth_path": true
  }
}
