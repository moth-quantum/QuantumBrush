{
    "name": "Game of Life",
    "id": "GoL",
    "author": "Daniel",
    "version": "1.0.0",
    "description": "This brush/lasso implements N iterations of a quantum cellular automata with a nearest neighbour neighbourhood.",
    "usage_instructions": "Draw a path (brush) or a closed loop (lasso if Radius is 0) to apply the cellular automata to the area.",
    "min_strokes": 1,
    "max_strokes": null,
    "selection_mode": "brush",
    "dependencies": {
        "numpy": ">=2.1.0",
        "colorsys": "",
        "qiskit": ">=1.0.0",
        "qiskit_ibm_runtime": ">=0.20.0",
        "qiskit_aer": ">=0.17.0"
    },
    "user_input": {
        "Iterations": {
            "type": "int",
            "label": "Iterations",
            "default": 1,
            "min": 1,
            "max": 10,
            "step": 1
        },
        "Mapping": {
            "type": "int",
            "label": "Mapping",
            "default": 0,
            "min": 0,
            "max": 5,
            "step": 1
        },
        "Radius": {
            "type": "int",
            "min": 0,
            "max": 100,
            "default": 0
        }
    },
    "stroke_input": {
        "image_rgba": "array",
        "path": "array"
    },
    "flags": {
        "smooth_path": true
    }
}