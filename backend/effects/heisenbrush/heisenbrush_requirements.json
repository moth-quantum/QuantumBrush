{
    "name": "Heisenbrush (continuous)",
    "id": "heisenbrush",
    "author": "Arianna",
    "version": "1.0.0",
    "description": "The Heisenbrush simulates color shifts through the Heisenberg spin model along a smooth path.",
    "usage_instructions": "Click and drag on the canvas in a single motion to apply the quantum shift.",
    "min_strokes": 1,
    "max_strokes": 1,
    "selection_mode": "brush",
    "dependencies": {
        "numpy": ">=2.1.0",
        "colorsys": "",
        "qiskit": ">=1.0.0",
        "qiskit_ibm_runtime": ">=0.20.0",
        "qiskit_aer": ">=0.17.0"
    },
    "user_input": {
        "Radius": {
            "type": "int",
            "min": 1,
            "max": 100,
            "default": 5
        },
        "Strength": {
            "type": "float",
            "min": 0.0,
            "max": 1.0,
            "default": 0.5
        },
        "Color": {
            "type": "color",
            "default": "#FF0000"
        }
    },
    "stroke_input": {
        "image_rgba": "array",
        "path": "array"
    },
    "flags": {
        "smooth_path": true
    }
}