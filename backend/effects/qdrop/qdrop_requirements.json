{
    "name": "Aquarela",
    "id": "qdrop",
    "author": "Joao",
    "version": "1.0.0",
    "description": "The Aquarela brush allows the user to mix colors generating new variations using entanglement.",
    "usage_instructions": "Click and drag in a single motion to apply watercolor drops.",
    "min_strokes": 1,
    "max_strokes": 1,
    "selection_mode": "brush",
    "dependencies": {
        "numpy": ">=2.1.0",
        "colorsys": ""
    },
    "user_input": {
        "Number of Drops": {
            "type": "int",
            "min": 2,
            "max": 15,
            "default": 5
        },
        "Radius": {
            "type": "int",
            "min": 0,
            "max": 100,
            "default": 20
        },
        "Strength": {
            "type": "float",
            "min": 0.0,
            "max": 1.0,
            "default": 1.0
        },
        "Target Color": {
            "type": "color",
            "default": "#FF0000"
        }
    },
    "stroke_input": {
        "image_rgba": "array",
        "path": "array",
        "clicks": "array"
    },
    "flags": {
        "smooth_path": true
    }
}