{
    "name": "Heisenbrush (discrete)",
    "id": "heisenbrush2",
    "author": "Arianna",
    "version": "1.0.0",
    "description": "The Heisenbrush simulates color shifts through the Heisenberg spin model with discrete segments.",
    "usage_instructions": "Click and drag multiple times (up to 10) to create segments. Each segment evolves the quantum state.",
    "min_strokes": 1,
    "max_strokes": 10,
    "selection_mode": "brush",
    "dependencies": {
        "numpy": ">=2.1.0",
        "colorsys": "",
        "qiskit": ">=1.0.0",
        "qiskit_ibm_runtime": ">=0.20.0",
        "qiskit_aer": ">=0.17.0"
    },
    "user_input": {
        "Radius": {
            "type": "int",
            "min": 1,
            "max": 100,
            "default": 5
        },
        "Strength": {
            "type": "float",
            "min": 0.0,
            "max": 1.0,
            "default": 0.5
        },
        "Color": {
            "type": "color",
            "default": "#FF0000"
        }
    },
    "stroke_input": {
        "image_rgba": "array",
        "path": "array",
        "clicks": "array"
    },
    "flags": {
        "smooth_path": false
    }
}