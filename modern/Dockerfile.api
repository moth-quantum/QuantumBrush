FROM python:3.11-slim

WORKDIR /app

# Quantum brushes need numpy, qiskit, etc. — use repo requirements
COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY effect /app/effect
COPY modern/dev-api/server.py /app/modern/dev-api/server.py

ENV QUANTUMBRUSH_ROOT=/app
ENV QB_DEV_API_PORT=8787
ENV PORT=8787

EXPOSE 8787

CMD ["python", "modern/dev-api/server.py"]
